# ---------------------------------------------------------------
# DEV LOCAL — SQLite fallback solo para Prisma CLI (db push, migrate).
# Runtime siempre usa Turso via adapter cuando TURSO_* están definidas.
# ---------------------------------------------------------------
DATABASE_URL="file:./custom.db"

# ---------------------------------------------------------------
# TURSO — DB en la nube (obligatoria en producción).
#   turso db create barbershope
#   turso db show --url barbershope           → TURSO_DATABASE_URL
#   turso db tokens create barbershope       → TURSO_AUTH_TOKEN
# ---------------------------------------------------------------
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# ---------------------------------------------------------------
# BASIC AUTH — /admin/* + mutaciones /api/* (excepto POST /api/appointments)
# ---------------------------------------------------------------
DEMO_USER="admin"
DEMO_PASS="cambia-esto"

# ---------------------------------------------------------------
# BRAND ACTIVO (opcional, default "obsidian")
# ---------------------------------------------------------------
NEXT_PUBLIC_BRAND="obsidian"
